name = "kuma-lite"
main = "src/index.ts"
compatibility_date = "2025-01-01"
compatibility_flags = ["nodejs_compat"]

# Template wrangler config. Copy to `wrangler.toml` and fill in your
# own values before running `wrangler deploy` / `wrangler dev`:
#
#   cp wrangler.toml.example wrangler.toml
#
# `wrangler.toml` itself is gitignored so your local edits never end
# up in this public fork.

# Workers Logs (Observability). Captures console logs and runtime metadata
# for every invocation, viewable in the Cloudflare dashboard under
# Workers & Pages → kuma-lite → Logs. Free plan retains 3 days of logs;
# paid plans retain 7 days.
#
# head_sampling_rate only applies to fetch invocations — scheduled (cron)
# invocations are always recorded at 100% regardless of this value. Sampling
# the public-page traffic at 10% is enough to spot recurring issues while
# leaving headroom against the 20M-logs/month included quota when /status
# gets linked publicly.
[observability]
enabled = true
head_sampling_rate = 0.1

# D1 database binding. Run `wrangler d1 create kuma-lite-db` and paste
# the returned database_id below before deploying.
[[d1_databases]]
binding = "DB"
database_name = "kuma-lite-db"
database_id = "<your-d1-database-id>"

# Service bindings to monitored Workers that share this Cloudflare
# account. A bare `fetch()` to *.workers.dev on the same account is
# rejected by the runtime with `error code: 1042` (same-zone
# recursion guard); routing through a service binding is the
# documented way to call a sibling Worker without leaving the
# Cloudflare network. Each binding name is referenced from the
# `monitors.service_binding` column in D1; the `service` value must
# match the destination Worker's name as registered with Workers
# Builds (see `wrangler whoami` / dashboard for current names).
#
# Uncomment and fill in one block per Worker you want to monitor.
# `binding` is your choice (it becomes the env key your monitor row
# references); `service` must match a Worker name in your account.
#
#   [[services]]
#   binding = "MY_API"
#   service = "<your-worker-name>"

# 1st cron: run checks every minute
# 2nd cron: clean up old `checks` rows daily at 03:00 UTC
[triggers]
crons = ["* * * * *", "0 3 * * *"]

[vars]
RETENTION_DAYS = "7"
# Optional: comma-separated list of monitor IDs to skip from public status
# page output. Useful for hiding internal endpoints.
# HIDDEN_MONITOR_IDS = ""
# Optional: Slack channel id (e.g. "C0123ABCD") used for outbound alerts
# and as the default channel for the `/status` slash command response.
# SLACK_DEFAULT_CHANNEL = ""

# Secrets (set via `wrangler secret put`):
#   DISCORD_WEBHOOK_URL    — Discord incoming webhook URL for alerts
#   API_TOKEN              — bearer token required by the management API
#   SLACK_BOT_TOKEN        — Slack bot token (xoxb-...). Required to enable Slack
#                            integration; together with SLACK_SIGNING_SECRET
#                            and SLACK_DEFAULT_CHANNEL it powers DOWN/recovery
#                            alerts and the `/status` slash command.
#   SLACK_SIGNING_SECRET   — Slack signing secret used to verify inbound
#                            webhooks at /slack/events.
