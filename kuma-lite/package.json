{
  "name": "kuma-lite",
  "version": "0.1.0",
  "private": true,
  "description": "Uptime Kuma-style monitoring on Cloudflare Workers + D1",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "tail": "wrangler tail",
    "schema:remote": "wrangler d1 execute kuma-lite-db --file=./schema.sql --remote",
    "schema:local": "wrangler d1 execute kuma-lite-db --file=./schema.sql --local",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250101.0",
    "typescript": "^5.5.0",
    "wrangler": "^4.88.0"
  },
  "dependencies": {
    "@chat-adapter/state-memory": "^4.27.0",
    "chat": "^4.27.0"
  }
}
